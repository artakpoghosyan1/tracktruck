# ─────────────────────────────────────────────────────────────
# TrackTruck API Server — environment variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=8080

# PostgreSQL — Replit provisions this automatically; for local dev run:
#   createdb tracktruck
#   export DATABASE_URL=postgres://localhost:5432/tracktruck
DATABASE_URL=postgres://localhost:5432/tracktruck

# JWT — change to a long random string in production:
#   openssl rand -hex 64
JWT_SECRET=change-me-use-openssl-rand-hex-64

# Google OAuth (optional — endpoint returns 503 when unset)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised JavaScript origin: http://localhost:3000 (dev) / your domain (prod)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Payment webhook HMAC secret (optional — skipped in NODE_ENV=development)
# Must match the secret configured in your payment gateway dashboard.
PAYMENT_WEBHOOK_SECRET=change-me-random-webhook-secret
