# ─────────────────────────────────────────────────────────────
# TrackTruck Live — frontend environment variables
# Copy this file to .env.local for local development.
# Variables prefixed with VITE_ are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# Dev server port (Replit overrides this automatically)
PORT=3000

# Base path (Replit sets this to the artifact path, e.g. /tracktruck)
# Leave as / for local development.
BASE_PATH=/

# API server URL — used by Vite to proxy /api requests during local dev.
# Point to wherever the API server is running.
API_URL=http://localhost:8080

# Mapbox public access token — required for map rendering.
# Create a token at https://account.mapbox.com/access-tokens/
# Scope needed: styles:read, tiles:read
VITE_MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJZT1VSX1RPS0VOIn0.example
