# ─────────────────────────────────────────────────────────────
# TrackTruck API Server — environment variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=8080

# PostgreSQL — Replit provisions this automatically; for local dev run:
#   createdb tracktruck
#   export DATABASE_URL=postgres://localhost:5432/tracktruck
DATABASE_URL=postgres://localhost:5432/tracktruck

# JWT — REQUIRED in production. Generate with: openssl rand -base64 48
# In production the server will exit immediately if this is missing or still the dev placeholder.
JWT_SECRET=change-me-use-openssl-rand-base64-48

# Root super-admin email — this address always gets the super_admin role and
# bypasses the allowed_emails gate. Set to your own email address.
# In production the server warns on startup if this is not set.
ROOT_ADMIN_EMAIL=you@example.com

# Google OAuth (optional — endpoint returns 503 when unset)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised JavaScript origin: http://localhost:3000 (dev) / your domain (prod)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
